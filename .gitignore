# SAMURAI Framework - .gitignore

# ─── Model weights (too large for git) ───────────────────
*.pth
*.h5
*.pkl

# ─── Generated image directories ─────────────────────────
*_clean_images/
*_images/
*_clean_images_by_class/

# ─── Generated CSV and data files ────────────────────────
*.csv
data/

# ─── Log files ────────────────────────────────────────────
*.log
logs/

# ─── Python cache ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/

# ─── Environment ──────────────────────────────────────────
.env
venv/
env/
*.egg-info/
dist/
build/

# ─── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── IDE files ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─── Plots (can be regenerated) ──────────────────────────
*.png
*.pdf

# ─── Keep these tracked ───────────────────────────────────
!README.md
!requirements.txt
!setup.sh
!run_pipeline.sh
!verify.py
!check_accuracy.py
!samurai.py
